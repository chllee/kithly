# AI backend env vars (Express server on port 3001)
# Copy this file to server/.env and fill in your values.
# Also copy .env.example to .env for the frontend.

# Supabase — find these in your project dashboard under Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — find this in Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Port the Express server listens on (default: 3001)
PORT=3001
