# Frontend env vars (Vite — must be prefixed with VITE_ to be exposed to the browser)
# Copy this file to .env and fill in your values.
# Also copy server/.env.example to server/.env for the AI backend.

# Supabase — find these in your project dashboard under Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
